      "rsvpInput": "12px",
      "rsvpChoice": "10px",
      "rsvpSubmit": "10px",
      "rsvpSuccessText": "26px",
      "rsvpSuccessSub": "11px",
      "footerNames": "30px",
      "footerNote": "10px"
    }
  },

  "spacing": {
    "containerWidth": "760px",
    "cardPadding": "28px",
    "sectionPaddingTop": "88px",
    "sectionPaddingInline": "24px",
    "detailsSectionPaddingTop": "88px",
    "sectionTagGap": "30px",
    "sectionTitleGap": "22px",
    "heroLabelGap": "16px",
    "heroDateGap": "22px",
    "scrollHintBottom": "20px",
    "scrollHintGap": "8px",

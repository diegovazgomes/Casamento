      "imperial_script": "'Imperial Script', cursive",
      "cookie": "'Cookie', cursive",
      "charm": "'Charm', cursive",
      "display": "'Jost', sans-serif",
      "body": "'Jost', sans-serif",
      "serif": "'Cormorant Garamond', serif",
      "accent": "'Great Vibes', cursive"
    },
    "roles": {
      "heroTitle": {
        "family": "great_vibes",
        "size": { "min": "54px", "fluid": "12vw", "max": "110px" },
        "weight": 400,
        "lineHeight": 1.1,
        "style": "normal"
      },
      "heroSubtitle": {
        "family": "jost",
        "size": "11px",
        "weight": 300,
        "lineHeight": 1.4,
        "style": "normal"
      },
      "eyebrow": {
        "family": "jost",
        "size": "9px",
        "weight": 300,
        "textTransform": "uppercase",
        "letterSpacing": "0.05em",
        "lineHeight": 1.2,
        "style": "normal"
      },
      "sectionTitle": {
        "family": "cormorant_garamond",
        "size": { "min": "34px", "fluid": "7vw", "max": "56px" },
        "weight": 300,
        "lineHeight": 1.2,
        "style": "normal"

# COPIE ESTE ARQUIVO PARA .env.local E PREENCHA OS VALORES
# NAO COMMITIR EM GIT (JA ESTA NO .gitignore)

# ============================================================
# SUPABASE (Obrigatorio)
# ============================================================
# Obtenha em: https://app.supabase.com > Settings > API

# URL do projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave publica — usada no frontend e em fetches sem autenticacao
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave privada de servico — usada APENAS no backend (Vercel Functions)
# NUNCA expor no frontend. Obtenha em Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# TWILIO (Opcional - apenas se quiser enviar WhatsApp)
# ============================================================
# Sem Twilio: lembretes serao apenas logados em reminder_logs
# Com Twilio: lembretes sao enviados via WhatsApp

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu_auth_token_aqui
TWILIO_PHONE_FROM=+5511999999999

# ============================================================
# NOTAS
# ============================================================
# 1. Salve este arquivo como .env.local na raiz do projeto
# 2. Se usar Vercel: adicione as variaveis em Settings > Environment Variables
# 3. DASHBOARD_PASSWORD foi removido — autenticacao agora usa Supabase Auth
# 4. Para testar localmente: use npx serve . e teste os endpoints

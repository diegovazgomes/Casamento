# COPIE ESTE ARQUIVO PARA .env.local E PREENCHA OS VALORES
# NAO COMMITIR EM GIT (JA ESTA NO .gitignore)

# ============================================================
# SUPABASE (Obrigatorio)
# ============================================================
# Obtenha em: https://app.supabase.com > Settings > API

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# DASHBOARD AUTH (Obrigatorio)
# ============================================================
# Escolha uma senha para acessar /dashboard.html
# Use algo forte: pelo menos 8 caracteres, numeros e simbolos

DASHBOARD_PASSWORD=seu-dashboard-password-aqui

# ============================================================
# TWILIO (Opcional - apenas se quiser enviar WhatsApp)
# ============================================================
# Sem Twilio: lembretes serao apenas logados em reminder_logs
# Com Twilio: lembretes sao enviados via WhatsApp

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu_auth_token_aqui
TWILIO_PHONE_FROM=+5511999999999

# ============================================================
# NOTAS
# ============================================================
# 1. Salve este arquivo como .env.local na raiz do projeto
# 2. Se usar Vercel: adicione essas variaveis em Settings > Environment Variables
# 3. Para testar localmente: use npx serve . e teste os endpoints

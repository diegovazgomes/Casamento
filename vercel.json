{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; media-src 'self' https://*.supabase.co; connect-src 'self' https://*.supabase.co https://cdn.jsdelivr.net; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/landing.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:slug((?!api|assets|.*\\..*).+)",
      "has": [
        {
          "type": "query",
          "key": "g",
          "value": "(?<g>.*)"
        },
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(WhatsApp|facebookexternalhit|Facebot|Twitterbot|Slackbot|TelegramBot|Discordbot).*"
        }
      ],
      "destination": "/api/event-config?mode=share&slug=:slug&g=:g"
    },
    {
      "source": "/:slug((?!api|assets|.*\\..*).+)",
      "destination": "/index.html"
    }
  ]
}